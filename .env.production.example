# habit-stack 本番 live 環境テンプレ (prod-direct、CF-013 分離)
# cp .env.production.example .env.production.local して live 実キーを入れる (gitignore 済)。
# ローカル開発用 dev/test は別ファイル。これは本番専用。

# --- Clerk production instance (live、clerk.habit-stack.givers.work DNS 要) ---
VITE_CLERK_PUBLISHABLE_KEY=pk_live_xxx
CLERK_SECRET_KEY=sk_live_xxx

# --- Neon prod DB ---
DATABASE_URL=postgresql://user:pass@host.neon.tech/habitstack?sslmode=require

# --- Stripe live ---
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
# webhook: https://habit-stack.givers.work/api/tip/webhook (event: checkout.session.completed) 登録後の whsec_
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Sentry (任意) ---
VITE_SENTRY_DSN=
SENTRY_DSN=

# --- 公開 URL (本番ドメイン) ---
APP_URL=https://habit-stack.givers.work

# --- feedback-hub (未構築なら空 = degrade) ---
HUB_FEEDBACK_ENDPOINT=
HUB_SERVICE_INFO_SECRET=
