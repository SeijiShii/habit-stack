# habit-stack DEV/test 環境テンプレート（CF-013 env 分離）
# これをコピーして .env.development.local を作り、実 dev/test キーを入れてください:
#   cp .env.development.example .env.development.local
# 本番 live キーは .env.production.local に分けて入れます（Phase 3）。

# --- Clerk（dev instance、test キー） ---
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# --- Neon（test/dev DB、無料枠） ---
DATABASE_URL=postgresql://user:pass@host.neon.tech/habitstack?sslmode=require

# --- Stripe（test モード） ---
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
# webhook secret は本番ドメイン確定後に Stripe dashboard で
#   https://habit-stack.givers.work/api/tip/webhook を登録して取得（Phase 3）
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- Sentry（任意、未配線なら空） ---
VITE_SENTRY_DSN=
SENTRY_DSN=

# --- 公開 URL（dev はローカル、prod は本番ドメイン） ---
APP_URL=http://localhost:5173

# --- feedback-hub（[論点-010]、未構築なら空 = degrade） ---
HUB_FEEDBACK_ENDPOINT=
HUB_SERVICE_INFO_SECRET=
