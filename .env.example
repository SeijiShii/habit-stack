# habit-stack 環境変数（実値は .env.local に、コミット禁止。SEC-003）
# クライアント公開可（VITE_ プレフィックス = バンドルに含まれる、publishable のみ）
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
VITE_SENTRY_DSN=

# サーバ専用（VITE_ を付けない = クライアント露出禁止）
# CLERK_PUBLISHABLE_KEY: サーバの authenticateRequest が必須。VITE_CLERK_PUBLISHABLE_KEY と同じ値。
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# GUEST_TOKEN_SECRET: 匿名ゲストの自前署名 guest JWT (HS256) の署名鍵 (C20260617-001)。
# 32+ 文字のランダム文字列。未設定でもクライアントはローカルゲストで degrade するが、
# owner churn 根治 + サーバ owner 検証のため本番では必ず設定する。例: openssl rand -base64 32
GUEST_TOKEN_SECRET=
DATABASE_URL=postgresql://user:pass@host.neon.tech/habitstack
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
SENTRY_DSN=

# 公開 URL（Checkout success/cancel）
APP_URL=http://localhost:5173

# feedback-hub（O40、[論点-010] hub 構築後に設定）
HUB_FEEDBACK_ENDPOINT=
HUB_SERVICE_INFO_SECRET=
